<script>
    // Buscador funcional integrado
    function filtrarContenido() {
        let input = document.getElementById('buscador').value.toLowerCase();
        let cards = document.getElementsByClassName('item-card');

        for (let i = 0; i < cards.length; i++) {
            let title = cards[i].querySelector('.item-title').innerText.toLowerCase();
            let desc = cards[i].querySelector('.item-desc') ? cards[i].querySelector('.item-desc').innerText.toLowerCase() : "";
            
            if (title.includes(input) || desc.includes(input)) {
                cards[i].style.display = "block";
            } else {
                cards[i].style.display = "none";
            }
        }
    }

    // Controlador de Acordeón Único
    function toggleGallery(id){
        let g = document.getElementById(id);
        g.style.display = (g.style.display === "block") ? "none" : "block";
    }

    // Funciones del visualizador de códigos QR
    function mostrarQR(ruta){
        document.getElementById("qr-overlay-img").src = ruta;
        document.getElementById("qr-overlay").style.display = "flex";
    }

    function cerrarQR(){
        document.getElementById("qr-overlay").style.display = "none";
    }
</script>

