    <style>
        :root {
            --bg: #f4f4f4;
            --text: #333;
            --accent: #ff7a00;
            --card-bg: #ffffff;
            --border: #ddd;
        }

        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            margin: 0; 
            line-height: 1.6;
        }

        .info-bar {
            background: #e9ecef;
            padding: 10px 20px;
            font-size: 11px;
            text-align: center;
            border-bottom: 1px solid var(--border);
            color: #665;
        }

        header {
            background: #fff;
            padding: 40px 20px;
            text-align: center;
            border-bottom: 3px solid var(--accent);
        }

        h1 { margin: 0; font-size: 1.8rem; color: var(--accent); letter-spacing: 1px; }

        .search-container {
            max-width: 600px;
            margin: 20px auto;
            padding: 0 20px;
        }
        .search-input {
            width: 100%; 
            padding: 15px; 
            border: 2px solid var(--accent); 
            border-radius: 30px;
            font-size: 16px;
            outline: none;
            box-sizing: border-box;
        }

        .main-container { max-width: 1200px; margin: auto; padding: 20px; }

        /* Misiones y Propósitos */
        .ecosistema-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin: 30px 0;
        }
        .ecosistema-card {
            background: #fff;
            padding: 20px;
            border-radius: 8px;
            border-left: 4px solid var(--accent);
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
            text-align: left;
        }
        .ecosistema-card h2 { margin-top: 0; font-size: 1.2rem; color: #111; }

        /* Secciones de Prensa / Editorial */
        .editorial {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            margin-bottom: 40px;
        }

        /* ACORDIONES Y CATEGORÍAS */
        .category {
            background: white;
            margin: 20px 0;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            border: 1px solid var(--border);
            overflow: hidden;
        }

        .category-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            padding: 20px;
            font-size: 1.1rem;
            font-weight: bold;
            background: #f8f9fa;
            transition: background 0.3s;
        }
        .category-header:hover { background: #f1f3f5; }

        .gallery {
            display: none;
            padding: 20px;
            background: #fff;
            border-top: 1px solid var(--border);
        }

        /* GRID DE CURSOS */
        .courses-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 25px;
            margin-top: 20px;
        }

        .course {
            background: #fafafa;
            border-radius: 10px;
            padding: 20px;
            border: 1px solid #eee;
            box-shadow: 0 2px 5px rgba(0,0,0,0.02);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .course img {
            width: 100%;
            height: auto;
            aspect-ratio: 16/9;
            object-fit: cover;
            border-radius: 8px;
            margin-bottom: 15px;
        }

        .course h3 { margin: 10px 0; font-size: 1.1rem; color: #000; }

        /* BOTONES */
        .botones {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: 15px;
        }

        .btn-buy {
            background: var(--accent);
            padding: 12px;  
            font-weight: bold;
            border-radius: 8px;
            text-decoration: none;
            color: white;
            text-align: center;
            font-size: 13px;
            transition: background 0.2s;
        }
        .btn-buy:hover { background: #e06b00; }

        .btn-qr {
            background: #e9ecef;
            color: #333;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            width: 100%;
        }

        /* OVERLAY QR */
        #qr-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.85);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 9999;
        }
        #qr-overlay img { width: 80vw; max-width: 350px; border-radius: 20px; }
        .cerrar { position: absolute; top: 25px; right: 25px; font-size: 35px; color: white; font-weight: bold; cursor: pointer; }

        /* NOTICIAS ESTILO PRENSA */
        .noticia-prensa {
            background: #ffffff;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.06);
            margin: 40px auto;
            overflow: hidden;
            border: 1px solid var(--border);
        }
        .noticia-header { padding: 30px; border-bottom: 1px solid #eaeaea; }
        .noticia-body { padding: 30px; }

        /* VIDEOS Y EMEDIDOS */
        .video-container {
            position: relative;
            padding-bottom: 56.25%;
            height: 0;
            overflow: hidden;
            border-radius: 8px;
            background: #f2f2f2;
            margin: 20px 0;
        }
        .video-container iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0; }

        /* WHATSAPP */
        .whatsapp-bubble {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background: #25d366;
            color: white;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 34px;
            text-decoration: none;
            box-shadow: 0 4px 10px rgba(0,0,0,0.3);
            z-index: 999;
        }

        footer { text-align: center; padding: 40px 20px; background: #000; color: #fff; font-size: 0.85rem; margin-top: 40px; }
        footer a { color: var(--accent); text-decoration: none; }
    </style>
</head>
